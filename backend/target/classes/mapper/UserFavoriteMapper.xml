<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.bookborrow.mapper.UserFavoriteMapper">

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_favorite (user_id, book_id) VALUES (#{userId}, #{bookId})
    </insert>

    <delete id="delete">
        DELETE FROM user_favorite WHERE user_id = #{userId} AND book_id = #{bookId}
    </delete>

    <select id="countByUserAndBook" resultType="int">
        SELECT COUNT(*) FROM user_favorite WHERE user_id = #{userId} AND book_id = #{bookId}
    </select>

    <select id="selectUserFavorites" resultMap="FavBookVOMap">
        SELECT b.id, b.isbn, b.title, b.author, b.publisher, b.publish_date,
               b.cover_url, b.category_id, bc.category_name,
               b.description, b.total_stock, b.current_stock, b.status,
               uf.create_time AS fav_time
        FROM user_favorite uf
        JOIN book_info b ON uf.book_id = b.id AND b.is_deleted = 0
        LEFT JOIN book_category bc ON b.category_id = bc.id
        WHERE uf.user_id = #{userId}
        ORDER BY uf.create_time DESC
    </select>

    <select id="countUserFavorites" resultType="int">
        SELECT COUNT(*) FROM user_favorite WHERE user_id = #{userId}
    </select>

    <resultMap id="FavBookVOMap" type="com.campus.bookborrow.dto.BookDetailVO">
        <id property="id" column="id"/>
        <result property="isbn" column="isbn"/>
        <result property="title" column="title"/>
        <result property="author" column="author"/>
        <result property="publisher" column="publisher"/>
        <result property="publishDate" column="publish_date"/>
        <result property="coverUrl" column="cover_url"/>
        <result property="categoryId" column="category_id"/>
        <result property="categoryName" column="category_name"/>
        <result property="description" column="description"/>
        <result property="totalStock" column="total_stock"/>
        <result property="currentStock" column="current_stock"/>
        <result property="status" column="status"/>
        <result property="createTime" column="fav_time"/>
    </resultMap>
</mapper>
